# ============================================================
# Food Hunger App — Backend Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to GitHub!
# ============================================================

# Database (SQLite for local, PostgreSQL URL for Render)
DATABASE_URL=sqlite+aiosqlite:///./foodhunger.db
DATABASE_URL_SYNC=sqlite:///./foodhunger.db

# Redis (get free instance from https://upstash.com)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# JWT Security
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Settings
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
DEV_MODE=false
DEV_OTP=123456

# Fast2SMS API Key (get from https://www.fast2sms.com)
FAST2SMS_API_KEY=YOUR_FAST2SMS_API_KEY_HERE

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,exp://localhost:8081

# ML Settings
ML_CLUSTER_RADIUS_KM=2.0
ML_MIN_SAMPLES=5
ML_RERUN_HOURS=6

# Scheduler
DONATION_EXPIRY_CHECK_MINUTES=5
